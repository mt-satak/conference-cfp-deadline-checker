# Design documents (gitignored, locally maintained)
concept.md
architecture.md

# Claude Code ローカルメモリ (~/.claude 配下のリポジトリ内コピー、共有対象外)
.claude/memory/

# Node
node_modules/
.pnpm-store/
.pnpm-debug.log*
npm-debug.log*
# このリポジトリは pnpm-lock.yaml を真の lockfile としているため npm の
# package-lock.json はトラッキングしない (Issue #106: deploy.yml では admin-api
# のみ workspace overrides を bypass するために npm install を走らせるが、
# CI 環境ごとの一時ファイルとして扱う)。
package-lock.json

# Environment files
.env
.env.local
.env.*.local

# IDE / OS
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# Build outputs
dist/
.astro/
.turbo/
# NOTE: 旧 `build/` パターンは削除。理由:
# - core.ignoreCase=true の環境で DDD aggregate `App\Domain\Build` の Build/
#   ディレクトリまで除外してしまうため (Linux 等は影響なし、macOS は影響あり)
# - 実害のある build/ 出力は各サブプロジェクトの .gitignore で個別管理 (例:
#   apps/admin-api/.gitignore の /public/build, frontend 着手時の dist 系)
# - Astro の場合は .astro/, dist/ で十分カバー

# CDK
cdk.out/
*.d.ts.map
*.js.map

# PHP / Composer
vendor/

# Logs
*.log
logs/

# Test artifacts
coverage/
.nyc_output/
