APP_NAME="Conference CfP Deadline Checker - Admin API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8080

APP_LOCALE=ja
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ja_JP

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── データベース ──
# 本アプリは Eloquent / SQL DB を使わない (アプリデータは DynamoDB)。
# Laravel の組み込み機能で DB を要求するもの (sessions / cache / queue) は
# 下で別ドライバに切り替えているため、DB_CONNECTION は明示的に未設定とする。
DB_CONNECTION=

# ── セッション (CSRF トークン保持に使う) ──
# Lambda は揮発性のため file ドライバ不可、DB ドライバも使わない。
# cookie ドライバ (暗号化 Cookie に保存) を採用。
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SAME_SITE=strict

# ── キャッシュ ──
# Lambda インスタンスメモリ内のみで完結する array ドライバを採用。
# 永続化が必要なキャッシュは出てきた時点で DynamoDB ドライバ等に切り替える。
CACHE_STORE=array

# ── キュー ──
# 本アプリにキュー処理は無い。同期実行 (sync) ドライバとする。
QUEUE_CONNECTION=sync

# ── ブロードキャスト・ファイルシステム ──
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ── メール ──
# 本アプリにメール送信機能は無い。stderr に流す log ドライバとする。
MAIL_MAILER=log

# ── AWS (DynamoDB アクセス用) ──
# 本番環境では Lambda 実行ロールで認証されるためキー類は空のまま。
# ローカル開発 (host で php artisan serve を実行する場合) は DynamoDB Local
# 向けに以下のダミー値を .env 側で設定する想定:
#   AWS_ACCESS_KEY_ID=dummy
#   AWS_SECRET_ACCESS_KEY=dummy
#   AWS_DYNAMODB_ENDPOINT=http://localhost:8000
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-northeast-1
# DynamoDB Local を使うときのみ設定する (host から見たエンドポイント)。
# 例: http://localhost:8000
AWS_DYNAMODB_ENDPOINT=

# ── DynamoDB テーブル名 (本番では CDK 出力と一致させる) ──
DYNAMODB_CONFERENCES_TABLE=cfp-conferences
DYNAMODB_CATEGORIES_TABLE=cfp-categories

# ── LLM URL 抽出 (Issue #40 Phase 3) ──
# プロバイダ切替: mock (default、ローカル開発・テスト用) / bedrock (本番)
# 本番では IAM 実行ロール経由で AWS Bedrock を呼ぶため、API キーの設定は一切不要
# (project memory: 長期 API キーをディスクに置かない方針)
LLM_PROVIDER=mock
# Bedrock モデル ID (本番のみ参照、mock では無視)
# 例: anthropic.claude-sonnet-4-6-20251010-v1:0 / apac.anthropic.claude-sonnet-4-6...
LLM_MODEL=anthropic.claude-sonnet-4-6
# Bedrock リージョン (省略時は AWS_DEFAULT_REGION を使う)
LLM_REGION=ap-northeast-1
