---
import type { Conference } from '../types/conference';
import { deadlineLabel } from '../lib/deadlineLabel';
import DeadlineBadge from './DeadlineBadge.astro';

/**
 * カンファレンス 1 件分のカード (Issue #86 / Phase 2)。
 *
 * SSG ビルド時 (Astro build) に static HTML を生成する。`today` をビルド時刻として
 * 締切ラベルを計算するため、Amplify が定期 rebuild する運用 (= Phase 5 で構築) で
 * 表示鮮度を保つ。
 */
interface Props {
    conference: Conference;
    today: Date;
}

const { conference, today } = Astro.props;
const label = deadlineLabel(conference.cfpEndDate, today);

const formatLabelMap = {
    online: 'オンライン',
    offline: 'オフライン',
    hybrid: 'ハイブリッド',
} as const;
const formatLabel = conference.format ? formatLabelMap[conference.format] : null;
---

<article class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm hover:border-emerald-300 hover:shadow transition">
    <div class="flex items-start justify-between gap-4">
        <h2 class="text-lg font-semibold text-gray-900 flex-1">
            <a href={conference.officialUrl} target="_blank" rel="noopener noreferrer"
               class="hover:text-emerald-700 hover:underline"
            >
                {conference.name}
            </a>
        </h2>
        <DeadlineBadge text={label.text} status={label.status} />
    </div>

    {conference.description && (
        <p class="mt-2 text-sm text-gray-600 leading-relaxed line-clamp-3">
            {conference.description}
        </p>
    )}

    <dl class="mt-4 grid grid-cols-1 gap-2 text-sm sm:grid-cols-2">
        {conference.eventStartDate && (
            <div>
                <dt class="text-gray-500">開催日</dt>
                <dd class="text-gray-900">
                    {conference.eventStartDate}
                    {conference.eventEndDate && conference.eventEndDate !== conference.eventStartDate && (
                        <> 〜 {conference.eventEndDate}</>
                    )}
                </dd>
            </div>
        )}
        {(conference.venue || formatLabel) && (
            <div>
                <dt class="text-gray-500">会場</dt>
                <dd class="text-gray-900">
                    {conference.venue}
                    {formatLabel && (
                        <span class="ml-2 inline-block rounded bg-gray-100 px-2 py-0.5 text-xs text-gray-600">{formatLabel}</span>
                    )}
                </dd>
            </div>
        )}
    </dl>

    {conference.categories.length > 0 && (
        <ul class="mt-3 flex flex-wrap gap-1.5">
            {conference.categories.map((cat) => (
                <li class="rounded bg-gray-50 px-2 py-0.5 text-xs text-gray-600 ring-1 ring-inset ring-gray-200">
                    {cat}
                </li>
            ))}
        </ul>
    )}
</article>
