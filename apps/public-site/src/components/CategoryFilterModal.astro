---
/**
 * カテゴリ絞り込みモーダル (公開フロントトップ用)。
 *
 * 元々は /categories/ 別ページにカテゴリ一覧を出していたが、戻る動線が
 * 弱く UX を損ねるため、トップ画面のオーバーレイモーダル化する。
 * /categories/{slug}/ 個別ページは SEO + シェアリンクの観点で維持。
 *
 * HTML5 native `<dialog>` element + 最小 JS で実装。Tailwind v4 で
 * backdrop / showModal / close のスタイリング。
 */

interface CategoryEntry {
    slug: string;
    count: number;
}

interface Props {
    categories: CategoryEntry[];
}

const { categories } = Astro.props;
---

<dialog
    id="category-filter-modal"
    class="m-auto rounded-xl border border-gray-200 bg-white p-0 shadow-xl backdrop:bg-gray-900/50 backdrop:backdrop-blur-sm w-full max-w-md mx-4 sm:mx-auto"
>
    <div class="flex items-center justify-between border-b border-gray-200 px-5 py-3">
        <h2 class="text-lg font-semibold text-gray-900">カテゴリで絞る</h2>
        <button
            type="button"
            id="category-filter-close"
            aria-label="閉じる"
            class="rounded-md p-1.5 text-gray-500 hover:bg-gray-100 hover:text-gray-700 transition"
        >
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M18 6L6 18M6 6l12 12"/>
            </svg>
        </button>
    </div>

    <div class="p-5">
        {categories.length === 0 ? (
            <p class="text-sm text-gray-600">現在募集中のカンファレンスはありません。</p>
        ) : (
            <ul class="grid gap-2 sm:grid-cols-2">
                {categories.map((c) => (
                    <li>
                        <a
                            href={`/categories/${c.slug}/`}
                            class="flex items-center justify-between rounded-lg border border-gray-200 bg-white px-3 py-2 hover:border-emerald-300 hover:bg-emerald-50 transition"
                        >
                            <span class="text-sm font-medium text-gray-900">{c.slug}</span>
                            <span class="rounded bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600">
                                {c.count} 件
                            </span>
                        </a>
                    </li>
                ))}
            </ul>
        )}
    </div>
</dialog>

{/*
  CSP script-src 'self' で inline script は禁止。Astro の <script> ブロックは
  小さなコードを inline 化する最適化が効いて load 不能になるため、public/ 配下に
  置いた純 JS を <script src="..."> で読み込む (Astro/vite の bundle を完全に
  bypass、Issue #124 follow-up)。is:inline 属性で Astro の hoist/bundle を抑止し、
  HTML として src 属性付き script タグをそのまま出力させる。
*/}
<script is:inline type="module" src="/scripts/category-filter-modal.js"></script>
