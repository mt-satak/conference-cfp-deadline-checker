---
import '../styles/global.css';
import { loadConferences } from '../data/loadConferences';
import { formatJstDate } from '../lib/dates';
import { filterOpenConferences } from '../lib/openConferences';
import { sortByDeadlineAsc } from '../lib/sortConferences';
import ConferenceCard from '../components/ConferenceCard.astro';
import Footer from '../components/Footer.astro';

/**
 * 公開フロントトップページ (Issue #86 / Phase 2 → Phase 3)。
 *
 * SSG: ビルド時に mock データから一覧 HTML を生成する。CfP 締切までの残り日数は
 * ビルド時刻 (= today) を基準に計算される。Phase 5 で Amplify を経由した日次
 * rebuild を組むと表示が日々更新される。
 *
 * Phase 4 で mock を admin-api の公開 API に置換する (= ファイル import を fetch
 * に変えるだけで描画は変わらない設計)。
 *
 * 表示フィルタ:
 * 「あと N 日」がサイトの目玉要素なので、まだ応募可能な open/urgent ステータス
 * のカンファレンスのみ一覧に出す。締切終了 (closed) / 締切未定 (unknown) は
 * 一覧から除外する。フィルタロジックは filterOpenConferences() に集約。
 */
const today = new Date();
const todayJst = formatJstDate(today);
const allConferences = await loadConferences();
const conferences = sortByDeadlineAsc(filterOpenConferences(allConferences, today));
---

<html lang="ja">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />
        <title>CfP Checker — 国内テックカンファレンス CfP 締切まとめ</title>
        <meta name="description" content="国内テックカンファレンスの CfP (Call for Proposals) 締切を一覧で確認できるサイト。" />
    </head>
    <body class="min-h-screen bg-gray-50 text-gray-900 antialiased">
        <header class="border-b border-gray-200 bg-white">
            <div class="mx-auto max-w-5xl px-4 py-6 sm:py-8">
                <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">
                    CfP Checker
                </h1>
                <p class="mt-1 text-sm text-gray-600">
                    国内テックカンファレンスの CfP (Call for Proposals) 締切まとめ
                </p>
            </div>
        </header>

        <main class="mx-auto max-w-5xl px-4 py-6 sm:py-8">
            <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
                <div class="flex items-baseline gap-3">
                    <h2 class="text-lg font-semibold text-gray-900">カンファレンス一覧</h2>
                    <span class="text-xs text-gray-500">{conferences.length} 件</span>
                </div>
                <a
                    href="/categories/"
                    class="inline-flex items-center rounded-md bg-emerald-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-emerald-700 active:bg-emerald-800 transition"
                >
                    カテゴリで絞る
                </a>
            </div>

            <ul class="grid gap-4 sm:grid-cols-2">
                {conferences.map((conference) => (
                    <li>
                        <ConferenceCard conference={conference} today={today} />
                    </li>
                ))}
            </ul>
        </main>

        <Footer todayJst={todayJst} />
    </body>
</html>
