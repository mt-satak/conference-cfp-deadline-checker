---
import '../styles/global.css';
import { loadConferences } from '../data/loadConferences';
import { formatJstDate } from '../lib/dates';
import { filterOpenConferences } from '../lib/openConferences';
import { sortByDeadlineAsc } from '../lib/sortConferences';
import { extractCategorySlugs, filterByCategory } from '../lib/categories';
import ConferenceCard from '../components/ConferenceCard.astro';
import CategoryFilterModal from '../components/CategoryFilterModal.astro';
import Footer from '../components/Footer.astro';

/**
 * 公開フロントトップページ (Issue #86 / Phase 2 → Phase 3)。
 *
 * SSG: ビルド時に mock データから一覧 HTML を生成する。CfP 締切までの残り日数は
 * ビルド時刻 (= today) を基準に計算される。Phase 5 で日次 rebuild を組むと
 * 表示が日々更新される。
 *
 * Phase 6 で「カテゴリで絞る」を別ページ遷移からモーダルに変更
 * (戻る動線の UX 改善)。/categories/{slug}/ 個別ページは SEO + シェアリンクの
 * 観点で維持。
 *
 * 表示フィルタ:
 * 「あと N 日」がサイトの目玉要素なので、まだ応募可能な open/urgent/today
 * ステータスのカンファレンスのみ一覧に出す。締切終了 (closed) / 締切未定
 * (unknown) は一覧から除外する。
 */
const today = new Date();
const todayJst = formatJstDate(today);
const allConferences = await loadConferences();
const openConferences = filterOpenConferences(allConferences, today);
const conferences = sortByDeadlineAsc(openConferences);

// モーダル用のカテゴリ + 件数集計 (open のもののみ)。
// 旧 /categories/ ページのロジックをここに集約する。
const categoryEntries = extractCategorySlugs(openConferences).map((slug) => ({
    slug,
    count: filterByCategory(openConferences, slug).length,
}));
---

<html lang="ja">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />
        <title>CfP Checker — 国内テックカンファレンス CfP 締切まとめ</title>
        <meta name="description" content="登壇したい人のためのシンプルな締切チェッカー。国内テックカンファレンスの CfP (Call for Proposals) 締切を一覧で確認できます。" />

        {/* Open Graph (SNS シェア時のプレビュー用、Issue #130 #2) */}
        <meta property="og:title" content="CfP Checker — 国内テックカンファレンス CfP 締切まとめ" />
        <meta property="og:description" content="登壇したい人のためのシンプルな締切チェッカー。国内テックカンファレンスの CfP 締切を一覧で確認できます。" />
        <meta property="og:image" content="https://cfp-checker.dev/og-image.png" />
        <meta property="og:type" content="website" />
        <meta property="og:url" content="https://cfp-checker.dev/" />
        <meta property="og:site_name" content="CfP Checker" />
        <meta property="og:locale" content="ja_JP" />

        {/* Twitter Card */}
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content="CfP Checker — 国内テックカンファレンス CfP 締切まとめ" />
        <meta name="twitter:description" content="登壇したい人のためのシンプルな締切チェッカー。国内テックカンファレンスの CfP 締切を一覧で確認できます。" />
        <meta name="twitter:image" content="https://cfp-checker.dev/og-image.png" />
        <meta name="twitter:site" content="@st_tm_k" />
        <meta name="twitter:creator" content="@st_tm_k" />
    </head>
    <body class="min-h-screen bg-gray-50 text-gray-900 antialiased">
        <header class="border-b border-gray-200 bg-white">
            <div class="mx-auto max-w-5xl px-4 py-6 sm:py-8">
                <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">
                    CfP Checker
                </h1>
                <p class="mt-1 text-sm text-gray-600">
                    国内テックカンファレンスの CfP (Call for Proposals) 締切まとめ
                </p>
            </div>
        </header>

        <main class="mx-auto max-w-5xl px-4 py-6 sm:py-8">
            <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
                <div class="flex items-baseline gap-3">
                    <h2 class="text-lg font-semibold text-gray-900">カンファレンス一覧</h2>
                    <span class="text-xs text-gray-500">{conferences.length} 件</span>
                </div>
                <button
                    type="button"
                    id="category-filter-open"
                    class="inline-flex items-center rounded-md bg-emerald-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-emerald-700 active:bg-emerald-800 transition"
                >
                    カテゴリで絞る
                </button>
            </div>

            <ul class="grid gap-4 sm:grid-cols-2">
                {conferences.map((conference) => (
                    <li>
                        <ConferenceCard conference={conference} today={today} />
                    </li>
                ))}
            </ul>
        </main>

        <Footer todayJst={todayJst} />

        <CategoryFilterModal categories={categoryEntries} />
    </body>
</html>
