---
import '../../styles/global.css';
import { loadConferences } from '../../data/loadConferences';
import { extractCategorySlugs, filterByCategory } from '../../lib/categories';
import { filterOpenConferences } from '../../lib/openConferences';
import { sortByDeadlineAsc } from '../../lib/sortConferences';
import { formatJstDate } from '../../lib/dates';
import ConferenceCard from '../../components/ConferenceCard.astro';
import Footer from '../../components/Footer.astro';

/**
 * カテゴリ別カンファレンス一覧ページ (Issue #86 / Phase 3 → 4.3)。
 *
 * SSG: `getStaticPaths` で全カテゴリ slug 分のページを事前生成する。
 *  - URL: `/categories/{slug}/`
 *  - 各ページに該当カテゴリの open/urgent カンファレンスを表示
 *
 * Phase 4.3 で loadConferences() (env 未設定時は mock fallback) に切替済み。
 * 公開 API 経由ではカテゴリ UUID が空配列に丸められるため (Phase 4.4 で解決予定)、
 * 現状 fetch モードでは getStaticPaths 結果が空 = カテゴリページが生成されない。
 */

export async function getStaticPaths() {
    const today = new Date();
    const allConferences = await loadConferences();
    const openConferences = filterOpenConferences(allConferences, today);
    return extractCategorySlugs(openConferences).map((slug) => ({
        params: { slug },
        props: { slug },
    }));
}

interface Props {
    slug: string;
}

const { slug } = Astro.props;
const today = new Date();
const todayJst = formatJstDate(today);
const allConferences = await loadConferences();
const conferences = sortByDeadlineAsc(
    filterByCategory(filterOpenConferences(allConferences, today), slug),
);
---

<html lang="ja">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />
        <title>{slug} — CfP Checker</title>
        <meta name="description" content={`${slug} カテゴリの開催予定カンファレンス一覧。CfP 締切までの残り日数を一覧で確認できます。`} />

        {/* Canonical URL (Issue #130 #5): 重複コンテンツ判定の回避。
            slug 単位で正規 URL を明示する。 */}
        <link rel="canonical" href={`https://cfp-checker.dev/categories/${slug}/`} />

        {/* Open Graph (SNS シェア時のプレビュー用、Issue #130 #2) */}
        <meta property="og:title" content={`${slug} カテゴリ — CfP Checker`} />
        <meta property="og:description" content={`${slug} カテゴリの開催予定カンファレンス一覧。CfP 締切までの残り日数を一覧で確認できます。`} />
        <meta property="og:image" content="https://cfp-checker.dev/og-image.png" />
        <meta property="og:type" content="website" />
        <meta property="og:url" content={`https://cfp-checker.dev/categories/${slug}/`} />
        <meta property="og:site_name" content="CfP Checker" />
        <meta property="og:locale" content="ja_JP" />

        {/* Twitter Card */}
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={`${slug} カテゴリ — CfP Checker`} />
        <meta name="twitter:description" content={`${slug} カテゴリの開催予定カンファレンス一覧。CfP 締切までの残り日数を一覧で確認できます。`} />
        <meta name="twitter:image" content="https://cfp-checker.dev/og-image.png" />
        <meta name="twitter:site" content="@st_tm_k" />
        <meta name="twitter:creator" content="@st_tm_k" />
    </head>
    <body class="min-h-screen bg-gray-50 text-gray-900 antialiased">
        <header class="border-b border-gray-200 bg-white">
            <div class="mx-auto max-w-5xl px-4 py-6 sm:py-8">
                <p class="text-xs text-gray-500">
                    <a href="/" class="hover:text-emerald-700 hover:underline">CfP Checker</a>
                    <span class="mx-1">/</span>
                    <span>{slug}</span>
                </p>
                <h1 class="mt-1 text-2xl font-bold tracking-tight sm:text-3xl">
                    {slug}
                </h1>
                <p class="mt-1 text-sm text-gray-600">
                    {slug} カテゴリのカンファレンス一覧
                </p>
            </div>
        </header>

        <main class="mx-auto max-w-5xl px-4 py-6 sm:py-8">
            <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
                <div class="flex items-baseline gap-3">
                    <h2 class="text-lg font-semibold text-gray-900">該当カンファレンス</h2>
                    <span class="text-xs text-gray-500" data-conference-count>{conferences.length} 件</span>
                </div>
                {/* 絞り込みを解除して全件表示 (= トップ) に戻すボタン。
                    パンくずだけだと戻る動線が弱いのでセカンダリボタンとして明示。 */}
                <a
                    href="/"
                    class="inline-flex items-center gap-1 rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:border-gray-400 hover:bg-gray-50 active:bg-gray-100 transition"
                >
                    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M19 12H5M12 19l-7-7 7-7"/>
                    </svg>
                    全件表示に戻す
                </a>
            </div>

            {conferences.length === 0 ? (
                <p class="text-sm text-gray-600">該当するカンファレンスはありません。</p>
            ) : (
                <ul class="grid gap-4 sm:grid-cols-2">
                    {conferences.map((conference) => (
                        <li>
                            <ConferenceCard conference={conference} today={today} />
                        </li>
                    ))}
                </ul>
            )}
        </main>

        <Footer todayJst={todayJst} />

        {/*
          クライアント側で「あと N 日」を再計算 (Issue #134)。SSG ビルド時刻が
          古くなって表示がずれるのを防ぐ。CSP script-src 'self' を通すため
          public/scripts/ 配下の純 JS を is:inline + src で外部参照する。
        */}
        <script is:inline type="module" src="/scripts/deadline-recalc.js"></script>
    </body>
</html>
