{
  "name": "@cfp/cdk",
  "version": "0.1.0",
  "private": true,
  "description": "AWS CDK infrastructure for Conference CfP Deadline Checker",
  "bin": {
    "cdk": "bin/cfp-deadline-checker.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "vitest run",
    "test:watch": "vitest",
    "cdk": "cdk",
    "synth": "cdk synth",
    "deploy": "cdk deploy",
    "diff": "cdk diff",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "aws-cdk": "2.1126.0",
    "esbuild": "^0.28.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.1068.0",
    "aws-cdk-lib": "2.259.0",
    "constructs": "^10.6.0",
    "source-map-support": "^0.5.21"
  }
}
