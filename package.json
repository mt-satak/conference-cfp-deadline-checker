{
  "name": "conference-cfp-deadline-checker",
  "private": true,
  "version": "0.1.0",
  "description": "国内テックカンファレンスの CfP 期限を一元的に確認できる公開情報サイト",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  }
}
