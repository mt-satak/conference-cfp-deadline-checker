#!/usr/bin/env bash
# プロジェクト pre-push フック
#
# push 前にバックエンド (admin-api) の以下 2 ゲートを実行する:
#   1. PHPStan (level max, ベースライン外の新規違反のみ報告)
#   2. テスト + カバレッジ計測 (層別 C1 閾値判定)
#
# 静的解析を先に走らせ、型不整合があれば即 fail する (テストより速いため)。
#
# 有効化: ルートの `pnpm install` (postinstall で自動設定) または
#         手動で `git config core.hooksPath .githooks`
#
# 緊急時バイパス:
#   SKIP_PHPSTAN=1 git push        PHPStan のみスキップ
#   SKIP_COVERAGE_CHECK=1 git push  カバレッジゲートのみスキップ
#   いずれも非推奨、CI でも弾かれる想定

set -euo pipefail

# プロジェクトルートに移動 (フック実行時は repo root が cwd だが念のため)
cd "$(git rev-parse --show-toplevel)"

# admin-api 配下のファイルが変更されているかを軽く判定
# (admin-api を一切触らない push でもカバレッジを回すのは無駄なため)
remote="${1:-origin}"
url="${2:-}"

# stdin から push 対象 ref を取得し、admin-api 関連変更があるかをチェック
needs_check=0
while read -r local_ref local_sha remote_ref remote_sha; do
    if [[ -z "$local_ref" ]]; then
        continue
    fi
    # 新規ブランチ push (remote_sha が全 0) は origin/main をベースに判定
    if [[ "$remote_sha" =~ ^0+$ ]]; then
        base=$(git merge-base "$local_sha" origin/main 2>/dev/null || git merge-base "$local_sha" origin/master 2>/dev/null || echo "")
        if [[ -z "$base" ]]; then
            # ベースが取れない (初回 push 等) は安全側に倒してカバレッジを実行
            needs_check=1
        elif git diff --name-only "$base" "$local_sha" -- apps/admin-api packages docker | grep -q .; then
            needs_check=1
        fi
    else
        if git diff --name-only "$remote_sha" "$local_sha" -- apps/admin-api packages docker | grep -q .; then
            needs_check=1
        fi
    fi
done

if [[ "$needs_check" == "0" ]]; then
    echo "✅ admin-api / packages / docker に変更が無いため admin-api ゲートをスキップ"
    exit 0
fi

# ── ゲート 1/3: Lint (Pint --test) ──
# CI と同じ dry-run モードで違反を検出する。違反は `make api-lint-fix` で
# (もしくは pnpm api:lint:fix で) 一括自動修正できる。
if [[ "${SKIP_PINT:-0}" == "1" ]]; then
    echo "⚠️  SKIP_PINT=1 により Pint ゲートをスキップしました"
else
    echo "▶ admin-api Pint (--test) を実行します"
    make api-lint
    echo "✅ Pint ゲート通過"
fi

# ── ゲート 2/3: PHPStan (level max) ──
if [[ "${SKIP_PHPSTAN:-0}" == "1" ]]; then
    echo "⚠️  SKIP_PHPSTAN=1 により PHPStan ゲートをスキップしました"
else
    echo "▶ admin-api PHPStan level max を実行します"
    make api-phpstan
    echo "✅ PHPStan ゲート通過"
fi

# ── ゲート 3/3: テスト + カバレッジ ──
if [[ "${SKIP_COVERAGE_CHECK:-0}" == "1" ]]; then
    echo "⚠️  SKIP_COVERAGE_CHECK=1 によりカバレッジゲートをスキップしました"
    exit 0
fi

echo "▶ admin-api テスト + カバレッジ計測を実行します (xdebug 必須)"
make api-test-coverage

echo "▶ 層別 C1 閾値判定"
make api-coverage-check

echo "✅ カバレッジゲート通過、push を続行します"
