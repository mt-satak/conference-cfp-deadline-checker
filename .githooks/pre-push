#!/usr/bin/env bash
# プロジェクト pre-push フック
#
# push 前にバックエンド (admin-api) のテスト + カバレッジ計測を実行し、
# C1 (Branch Coverage) が 90% を下回る push を遮断する。
#
# 有効化: ルートの `pnpm install` (postinstall で自動設定) または
#         手動で `git config core.hooksPath .githooks`
#
# 緊急時バイパス: SKIP_COVERAGE_CHECK=1 git push (推奨しない、CI でも弾かれる想定)

set -euo pipefail

if [[ "${SKIP_COVERAGE_CHECK:-0}" == "1" ]]; then
    echo "⚠️  SKIP_COVERAGE_CHECK=1 によりカバレッジゲートをスキップしました"
    exit 0
fi

# プロジェクトルートに移動 (フック実行時は repo root が cwd だが念のため)
cd "$(git rev-parse --show-toplevel)"

# admin-api 配下のファイルが変更されているかを軽く判定
# (admin-api を一切触らない push でもカバレッジを回すのは無駄なため)
remote="${1:-origin}"
url="${2:-}"

# stdin から push 対象 ref を取得し、admin-api 関連変更があるかをチェック
needs_check=0
while read -r local_ref local_sha remote_ref remote_sha; do
    if [[ -z "$local_ref" ]]; then
        continue
    fi
    # 新規ブランチ push (remote_sha が全 0) は HEAD 全部を対象に判定
    if [[ "$remote_sha" =~ ^0+$ ]]; then
        if git diff --name-only "$local_sha" -- apps/admin-api packages docker | grep -q .; then
            needs_check=1
        fi
    else
        if git diff --name-only "$remote_sha" "$local_sha" -- apps/admin-api packages docker | grep -q .; then
            needs_check=1
        fi
    fi
done

if [[ "$needs_check" == "0" ]]; then
    echo "✅ admin-api / packages / docker に変更が無いためカバレッジゲートをスキップ"
    exit 0
fi

echo "▶ admin-api テスト + カバレッジ計測を実行します (xdebug 必須)"
make api-test-coverage

echo "▶ C1 (Branch Coverage) 90% 判定"
make api-coverage-check

echo "✅ カバレッジゲート通過、push を続行します"
