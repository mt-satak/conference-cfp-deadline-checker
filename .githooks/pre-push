#!/usr/bin/env bash
# プロジェクト pre-push フック
#
# push 前に各アプリのゲートを実行する:
#   admin-api : Pint / PHPStan / Pest + 層別 C1 カバレッジ
#   public-site: astro check (typecheck) / Vitest + coverage
#
# CI は速度優先で coverage を取らないため、coverage 検知は本フックが最終ガード。
#
# 有効化: ルートの `pnpm install` (postinstall で自動設定) または
#         手動で `git config core.hooksPath .githooks`
#
# 緊急時バイパス:
#   SKIP_PINT=1                      Pint ゲートのみスキップ (admin-api)
#   SKIP_PHPSTAN=1                   PHPStan ゲートのみスキップ (admin-api)
#   SKIP_COVERAGE_CHECK=1            admin-api カバレッジゲートのみスキップ
#   SKIP_PUBLIC_SITE=1               public-site ゲート全体をスキップ
#   いずれも非推奨、commit message にバイパス理由を残すこと

set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

# 引数 (git pre-push hook の標準: $1=remote name, $2=remote URL)
remote="${1:-origin}"
url="${2:-}"

# ── 変更検出ロジック ──
# stdin から push 対象 ref を取得し、指定パスに変更があるかを判定するヘルパ。
# 標準入力は 1 度しか読めないため、最初に全行を配列に取り込む。
push_refs=()
while read -r line; do
    push_refs+=("$line")
done

has_changes_in() {
    local paths=("$@")
    for ref_line in "${push_refs[@]}"; do
        if [[ -z "$ref_line" ]]; then
            continue
        fi
        # shellcheck disable=SC2086
        read -r local_ref local_sha remote_ref remote_sha <<<"$ref_line"
        if [[ -z "${local_ref:-}" ]]; then
            continue
        fi
        if [[ "${remote_sha:-}" =~ ^0+$ ]]; then
            # 新規ブランチ push: origin/main をベースに判定。ベース不明時は安全側に倒す
            base=$(git merge-base "$local_sha" origin/main 2>/dev/null || git merge-base "$local_sha" origin/master 2>/dev/null || echo "")
            if [[ -z "$base" ]]; then
                return 0
            elif git diff --name-only "$base" "$local_sha" -- "${paths[@]}" | grep -q .; then
                return 0
            fi
        else
            if git diff --name-only "$remote_sha" "$local_sha" -- "${paths[@]}" | grep -q .; then
                return 0
            fi
        fi
    done
    return 1
}

# ────────────────────────────────────────────────────────────────────
# admin-api ゲート
# ────────────────────────────────────────────────────────────────────
if has_changes_in apps/admin-api packages docker; then
    if [[ "${SKIP_PINT:-0}" == "1" ]]; then
        echo "⚠️  SKIP_PINT=1 により Pint ゲートをスキップしました"
    else
        echo "▶ admin-api Pint (--test) を実行します"
        make api-lint
        echo "✅ Pint ゲート通過"
    fi

    if [[ "${SKIP_PHPSTAN:-0}" == "1" ]]; then
        echo "⚠️  SKIP_PHPSTAN=1 により PHPStan ゲートをスキップしました"
    else
        echo "▶ admin-api PHPStan level max を実行します"
        make api-phpstan
        echo "✅ PHPStan ゲート通過"
    fi

    if [[ "${SKIP_COVERAGE_CHECK:-0}" == "1" ]]; then
        echo "⚠️  SKIP_COVERAGE_CHECK=1 により admin-api カバレッジゲートをスキップしました"
    else
        echo "▶ admin-api テスト + カバレッジ計測を実行します (xdebug 必須)"
        make api-test-coverage
        echo "▶ admin-api 層別 C1 閾値判定"
        make api-coverage-check
        echo "✅ admin-api カバレッジゲート通過"
    fi
else
    echo "✅ admin-api / packages / docker に変更が無いため admin-api ゲートをスキップ"
fi

# ────────────────────────────────────────────────────────────────────
# public-site ゲート (Issue #86)
# ────────────────────────────────────────────────────────────────────
if [[ "${SKIP_PUBLIC_SITE:-0}" == "1" ]]; then
    echo "⚠️  SKIP_PUBLIC_SITE=1 により public-site ゲートをスキップしました"
elif has_changes_in apps/public-site packages package.json pnpm-lock.yaml; then
    echo "▶ public-site typecheck (astro check) を実行します"
    pnpm --filter apps-public-site typecheck
    echo "✅ public-site typecheck 通過"

    echo "▶ public-site テスト + カバレッジ計測 (Vitest --coverage) を実行します"
    pnpm --filter apps-public-site test:coverage
    echo "✅ public-site カバレッジゲート通過"
else
    echo "✅ apps/public-site に変更が無いため public-site ゲートをスキップ"
fi

echo "✅ すべてのゲート通過、push を続行します"
